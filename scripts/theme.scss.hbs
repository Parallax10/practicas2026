// Autogenerado por Handlebars
$primary-color: {{theme.primaryColor}};

.navbar {
    display: flex;
    flex-direction: {{theme.navDirection}};
    background-color: $primary-color;
}

.productGrid {
    display: grid;
    grid-template-columns: {{theme.productsGrid}};
    gap: 20px;
}

.card {
    background-color: {{theme.cardBackground}};
    border: 1px solid darken({{theme.cardBackground}}, 10%);
}