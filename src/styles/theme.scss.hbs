@import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&display=swap');

/* ==========================================================================
   VARIABLES DINÁMICAS GLOBALES
   ========================================================================== */
$primary: {{#if colors.primary}}{{colors.primary}}{{else}}#e3000f{{/if}};
$secondary: {{#if colors.secondary}}{{colors.secondary}}{{else}}#000000{{/if}};
$bg-light: {{#if colors.bg_light}}{{colors.bg_light}}{{else}}#ffffff{{/if}};
$bg-body: {{#if colors.bg_body}}{{colors.bg_body}}{{else}}#f4f4f4{{/if}};
$border: {{#if colors.border}}{{colors.border}}{{else}}#e0e0e0{{/if}};
$text: {{#if colors.text}}{{colors.text}}{{else}}#333333{{/if}};

:global(body) { 
    margin: 0; 
    font-family: {{#if fonts.main}}{{{fonts.main}}}{{else}}'Roboto', sans-serif{{/if}}; 
    background-color: $bg-body; 
    color: $text; 
}

/* ==========================================================================
   ENSAMBLAJE DE COMPONENTES
   ========================================================================== */
{{> navbar }}
{{> filters }}
{{> cards }}
{{> footer }}
{{> details }}
{{> utilities }}