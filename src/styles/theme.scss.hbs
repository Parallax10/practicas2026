@import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap');

$primary: {{theme.colors.primary}};
$secondary: {{theme.colors.secondary}};
$text: {{theme.colors.text}};
$bg-body: {{theme.colors.bg_body}};
$border: {{theme.colors.border}};
$font-main: {{{theme.fonts.main}}};

:global(body) {
    margin: 0;
    font-family: $font-main;
    background-color: $bg-body;
}

// NAVBAR REAL
.navbar {
    background: #fff;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    .topBar {
        background: $secondary;
        color: #fff;
        font-size: 12px;
        padding: 8px 0;
        text-align: center;
    }
    .headerMain {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 0;
        .logo { font-size: 28px; font-weight: 900; color: $secondary; letter-spacing: -1px; }
        .search {
            flex: 1; max-width: 500px; display: flex; margin: 0 40px;
            input { width: 100%; padding: 12px; border: 1px solid $border; border-radius: 4px 0 0 4px; }
            button { background: $primary; color: #fff; border: none; padding: 0 20px; border-radius: 0 4px 4px 0; cursor: pointer; }
        }
    }
    .navLinks {
        display: flex; justify-content: center; gap: 30px; padding: 15px 0;
        border-top: 1px solid $border; font-weight: 700; font-size: 14px;
        span { cursor: pointer; &:hover { color: $primary; } }
    }
}

// LAYOUT DOS COLUMNAS
.pageLayout {
    display: flex;
    gap: {{theme.layout.gap}};
    max-width: {{theme.layout.maxWidth}};
    margin: 40px auto;
    padding: 0 20px;
}

.sidebar {
    width: {{theme.layout.sidebarWidth}};
    .filterBlock {
        background: #fff; border: 1px solid $border; border-radius: 4px; padding: 20px; margin-bottom: 20px;
        h4 { margin: 0 0 15px; font-size: 14px; border-bottom: 2px solid $primary; display: inline-block; }
        label { display: block; margin: 10px 0; font-size: 13px; cursor: pointer; input { margin-right: 10px; } }
    }
}

.productGrid {
    display: grid;
    grid-template-columns: {{theme.layout.productsGrid}};
    gap: 20px;
    flex: 1;
}

// TARJETA DE PRODUCTO (BOTÓN VER VEHÍCULO)
.card {
    background: #fff; border: 1px solid $border; border-radius: 4px; padding: 15px;
    display: flex; flex-direction: column; transition: transform 0.2s;
    &:hover { transform: translateY(-5px); box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
    .imgBox { height: 180px; display: flex; align-items: center; justify-content: center; margin-bottom: 15px; img { max-height: 100%; } }
    .price { font-size: 22px; font-weight: 900; color: $primary; margin: 10px 0; }
    .btn { 
        background: $secondary; color: #fff; border: none; padding: 12px; 
        font-weight: 700; text-transform: uppercase; cursor: pointer; margin-top: auto;
        &:hover { background: $primary; }
    }
}