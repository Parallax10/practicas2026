// src/styles/theme.scss.hbs
$primary: {{theme.primaryColor}};

.contenedorPrincipal {
    background-color: #f5f5f5;
    min-height: 100vh;
}

.layoutWrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
}

.productGrid {
    display: grid;
    grid-template-columns: {{theme.gridColumns}};
    gap: 15px;
    padding: 20px;
}

.cardCustom {
    background-color: {{theme.cardBg}};
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 1rem;
}