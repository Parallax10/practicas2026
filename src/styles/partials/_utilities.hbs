/* ==========================================================================
   6. UTILIDADES FIJAS (Independientes del estilo)
   ========================================================================== */

.sizeSelector { 
    margin-bottom: 30px; 
    
    h4 { 
        font-size: 14px; 
        text-transform: uppercase; 
        color: inherit; 
        font-weight: 900; 
        margin-bottom: 15px; 
    } 
    .sizeGrid { 
        display: flex; 
        flex-wrap: wrap; 
        gap: 12px; 
        
        .sizePill { 
            padding: 12px 20px; 
            border: 2px solid $border; 
            background: $bg-light; 
            border-radius: 6px; 
            font-size: 14px; 
            font-weight: 900; 
            cursor: pointer; 
            transition: all 0.2s; 
            
            &:hover { 
                border-color: $primary; 
            } 
            &.selected { 
                border-color: $primary; 
                background: $primary; 
                color: #fff; 
            } 
        } 
    } 
}

.authPage { 
    max-width: 500px; 
    margin: 100px auto; 
    padding: 0 20px; 
}

.authBox { 
    background: $bg-light; 
    padding: 40px; 
    border-radius: 12px; 
    box-shadow: 0 10px 30px rgba(0,0,0,0.1); 
    text-align: center; 
    border-top: 6px solid $primary; 
    
    h2 { 
        font-size: 28px; 
        font-weight: 900; 
        margin-bottom: 30px; 
        text-transform: uppercase; 
        color: inherit; 
    } 
    input { 
        width: 100%; 
        padding: 18px; 
        margin-bottom: 20px; 
        border: 2px solid $border; 
        border-radius: 6px; 
        font-size: 16px; 
        outline: none; 
        background: transparent; 
        color: inherit; 
        
        &:focus { 
            border-color: $primary; 
        } 
    } 
}

.badgeCount { 
    position: absolute; 
    top: -10px; 
    right: -5px; 
    background: red; 
    color: #fff; 
    font-size: 11px; 
    font-weight: 900; 
    width: 20px; 
    height: 20px; 
    border-radius: 50%; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    border: 2px solid $bg-body; 
}

.heartBtn { 
    position: absolute; 
    top: 15px; 
    right: 15px; 
    font-size: 26px; 
    cursor: pointer; 
    z-index: 10; 
    transition: transform 0.2s; 
    background: $bg-light; 
    border-radius: 50%; 
    width: 45px; 
    height: 45px; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    box-shadow: 0 4px 10px rgba(0,0,0,0.15); 
    border: 1px solid $border; 
    
    &:hover { 
        transform: scale(1.1); 
    } 
    &.isFav { 
        color: red; 
    } 
}